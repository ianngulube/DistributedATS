	cd /home/ianngulube/Documents/Code/cpp/Experimental_2/DistributedATS/build && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
